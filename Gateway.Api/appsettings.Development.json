{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AuthOptions": {
    "Audience": "gateway.api",
    "Issuer": "http://localhost:5109",
    "SecurityKey": "top_secret_security_key_top_secret_security_key_top_secret_security_key_top_secret_security_key"
  },

  "ReverseProxy": {

    "Routes": {
      "user-create-route": {
        "ClusterId": "user.cluster",
        "Match": {
          "Path": "users/create"
        },
        "Transforms": [
          {
            "PathPattern": "api/users/create"
          }
        ]
      },
      "user-login-route": {
        "ClusterId": "user.cluster",
        "Match": {
          "Path": "users/login"
        },
        "Transforms": [
          {
            "PathPattern": "api/users/login"
          }
        ]
      },
      "user-login-by-refresh-token-route": {
        "ClusterId": "user.cluster",
        "Match": {
          "Path": "users/loginByRefreshToken"
        },
        "Transforms": [
          {
            "PathPattern": "api/users/loginByRefreshToken"
          }
        ]
      },
      "user-delete-route": {
        "ClusterId": "user.cluster",
        "Match": {
          "Path": "users/delete"
        },
        "Transforms": [
          {
            "PathPattern": "api/users/delete"
          }
        ],
        "AuthorizationPolicy": "user"
      }
    },


    "Clusters": {

      "user.cluster": {
        "Destinations": {
          "destination": {
            "Address": "http://localhost:5109"
          }
        }
      }

    }




  }
}

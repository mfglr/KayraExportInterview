{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "RabbitMQOptions": {
    "Host": "localhost",
    "VirtualHost": "KayraExport",
    "Password": "guest",
    "UserName": "guest"
  },

  "AuthOptions": {
    "Audience": "gateway.api",
    "Issuer": "http://localhost:5109",
    "SecurityKey": "top_secret_security_key_top_secret_security_key_top_secret_security_key_top_secret_security_key"
  },

  "ReverseProxy": {

    "Routes": {
      "user-create": {
        "ClusterId": "user.cluster",
        "Match": { "Path": "users/create" },
        "Transforms": [ { "PathPattern": "api/users/create" } ]
      },
      "user-login": {
        "ClusterId": "user.cluster",
        "Match": { "Path": "users/login" },
        "Transforms": [ { "PathPattern": "api/users/login" } ]
      },
      "user-login-refresh": {
        "ClusterId": "user.cluster",
        "Match": { "Path": "users/loginByRefreshToken" },
        "Transforms": [ { "PathPattern": "api/users/loginByRefreshToken" } ]
      },
      "user-delete": {
        "ClusterId": "user.cluster",
        "Match": { "Path": "users/delete" },
        "Transforms": [ { "PathPattern": "api/users/delete" } ],
        "AuthorizationPolicy": "user"
      },

      "product-query": {
        "ClusterId": "product.cluster",
        "Match": { "Path": "products/query/{**catch-all}" },
        "Transforms": [ { "PathPattern": "api/products/{**catch-all}" } ]
      },
      "product-command": {
        "ClusterId": "product.cluster",
        "Match": { "Path": "products/{**catch-all}" },
        "Transforms": [ { "PathPattern": "api/products/{**catch-all}" } ],
        "AuthorizationPolicy": "user"
      }
    },

    "Clusters": {
      "user.cluster": { "Destinations": { "destination": { "Address": "http://localhost:5109" } } },
      "product.cluster": { "Destinations": { "destination": { "Address": "http://localhost:5182" } } }
    }
  }
}

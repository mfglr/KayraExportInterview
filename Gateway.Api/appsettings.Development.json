{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ReverseProxy": {

    "Routes": {
      "user-create-route": {
        "ClusterId": "user.cluster",
        "Match": {
          "Path": "users/create"
        },
        "Transforms": [
          {
            "PathPattern": "api/users/create"
          }
        ]
      }
    },


    "Clusters": {

      "user.cluster": {
        "Destinations": {
          "destination": {
            "Address": "http://localhost:5109"
          }
        }
      }

    }




  }
}
